{
  "manifest_version": 3,
  "name": "Enma - Quorum council overlay",
  "version": "0.6.0",
  "description": "Ask Enma about the stock on screen. Enma convenes the Quorum council via your LOCAL quorum serve - math decides, Enma narrates. Self-hosted; AI analysis, not investment advice.",
  "permissions": ["alarms", "notifications"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "icons": {
    "16": "icons/enma-16.png",
    "48": "icons/enma-48.png",
    "128": "icons/enma-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tradingview.com/*",
        "*://kite.zerodha.com/*",
        "*://kite-demo.zerodha.com/*"
      ],
      "js": ["src/tickers.js", "src/intent.js", "src/panel.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Toggle Enma (Ctrl+Shift+Q)",
    "default_icon": {
      "16": "icons/enma-16.png",
      "48": "icons/enma-48.png",
      "128": "icons/enma-128.png"
    }
  },
  "commands": {
    "toggle-enma": {
      "suggested_key": { "default": "Ctrl+Shift+Q" },
      "description": "Toggle the Enma panel"
    }
  }
}
